{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Authority Graph",
  "description": "Schema for representing agents, principals, authority relationships, and resolution context in Agent Arbiter.",
  "type": "object",
  "required": ["principals", "agents", "edges"],
  "properties": {
    "scenario": {
      "type": "string",
      "description": "Optional short title for the scenario this graph describes."
    },
    "description": {
      "type": "string",
      "description": "Optional human-readable summary of the scenario and its expected outcome."
    },
    "principals": {
      "type": "array",
      "description": "Real-world identities such as organizations, roles, systems, or contract parties.",
      "items": {
        "type": "object",
        "required": ["id", "type", "name"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique principal identifier."
          },
          "type": {
            "type": "string",
            "enum": ["organization", "role", "system", "contract_party", "policy", "regulator", "user"]
          },
          "name": {
            "type": "string",
            "description": "Human-readable principal name."
          },
          "domain": {
            "type": "array",
            "description": "Optional list of domains in which this principal is eligible to hold or receive authority. If omitted, the principal is eligible in every domain. Domains match by exact string comparison.",
            "items": {
              "type": "string"
            }
          },
          "metadata": {
            "type": "object",
            "description": "Optional extension data.",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "agents": {
      "type": "array",
      "description": "Computational actors that represent principals and propose actions.",
      "items": {
        "type": "object",
        "required": ["id", "principal_id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique agent identifier."
          },
          "principal_id": {
            "type": "string",
            "description": "Identifier of the principal represented by this agent."
          },
          "name": {
            "type": "string",
            "description": "Human-readable agent name."
          },
          "domain": {
            "type": "array",
            "description": "Optional list of domains in which this agent is eligible to hold or receive authority. If omitted, the agent is eligible in every domain. Domains match by exact string comparison.",
            "items": {
              "type": "string"
            }
          },
          "metadata": {
            "type": "object",
            "description": "Optional extension data.",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "description": "Directed authority relationships between principals or agents.",
      "items": {
        "type": "object",
        "required": ["from", "to", "layer", "domain", "relationship"],
        "properties": {
          "from": {
            "type": "string",
            "description": "Source principal or agent identifier."
          },
          "to": {
            "type": "string",
            "description": "Target principal or agent identifier."
          },
          "layer": {
            "type": "string",
            "enum": ["constitutional", "institutional", "system", "agent"],
            "description": "Authority layer for this relationship."
          },
          "domain": {
            "type": "string",
            "description": "The single domain in which this authority relationship applies. An edge is considered only when its domain exactly matches the active decision domain."
          },
          "relationship": {
            "type": "string",
            "enum": ["governs", "delegates", "owns_truth", "constrains", "represents"],
            "description": "Type of authority relationship."
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Optional bounded weight for precedence within a layer."
          },
          "scope": {
            "type": "object",
            "description": "Optional delegation or authority limits.",
            "properties": {
              "actions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "time_window": {
                "type": "string"
              },
              "constraints": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          },
          "metadata": {
            "type": "object",
            "description": "Optional extension data.",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "context": {
      "type": "object",
      "description": "Optional runtime context for evaluating authority.",
      "properties": {
        "domain": {
          "type": "string",
          "description": "Active decision domain, matched exactly against edge domains."
        },
        "system_of_record": {
          "type": "string",
          "description": "Identifier of the principal or agent that owns factual truth in this domain."
        },
        "constraints": {
          "type": "array",
          "description": "Active constraints in the current context.",
          "items": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object",
          "description": "Optional extension data.",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "conflict": {
      "type": "object",
      "description": "Optional conflict set: competing proposals to be resolved within a single domain.",
      "required": ["domain", "proposals"],
      "properties": {
        "domain": {
          "type": "string",
          "description": "Domain in which the proposals conflict, matched exactly against edge domains."
        },
        "proposals": {
          "type": "array",
          "description": "Competing actions proposed by agents.",
          "items": {
            "type": "object",
            "required": ["id", "agent", "action"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique proposal identifier."
              },
              "agent": {
                "type": "string",
                "description": "Identifier of the proposing agent."
              },
              "action": {
                "type": "string",
                "description": "Action being proposed."
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "resolution": {
      "type": "object",
      "description": "Optional declared resolution: the expected outcome for this scenario.",
      "required": ["selected_agent", "reason"],
      "properties": {
        "rule": {
          "type": "string",
          "description": "Resolution rule applied, e.g. selected = argmax(authority(agent, context))."
        },
        "authority_scores": {
          "type": "object",
          "description": "Within-layer authority weight per agent identifier.",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "selected_agent": {
          "type": "string",
          "description": "Identifier of the agent whose proposal is selected."
        },
        "selected_principal": {
          "type": "string",
          "description": "Identifier of the principal represented by the selected agent."
        },
        "selected_action": {
          "type": "string",
          "description": "Action selected from the conflict set."
        },
        "reason": {
          "type": "string",
          "description": "Explanation attributing the outcome to authority sources."
        },
        "rejected": {
          "type": "array",
          "description": "Proposals rejected by the resolution, with reasons.",
          "items": {
            "type": "object",
            "required": ["proposal_id", "reason"],
            "properties": {
              "proposal_id": {
                "type": "string",
                "description": "Identifier of the rejected proposal."
              },
              "reason": {
                "type": "string",
                "description": "Why the proposal was rejected."
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
