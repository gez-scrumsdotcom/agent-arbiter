{
  "scenario": "Organizational Hierarchy",
  "description": "Authority flows through organizational structure. The CEO agent holds the highest within-layer weight; the finance and sales agents tie at 0.9 and illustrate the deterministic tie-break.",

  "context": {
    "domain": "decision"
  },

  "principals": [
    { "id": "ceo", "type": "role", "name": "CEO" },
    { "id": "finance-head", "type": "role", "name": "Head of Finance" },
    { "id": "sales-head", "type": "role", "name": "Head of Sales" }
  ],

  "agents": [
    { "id": "ceo-agent", "principal_id": "ceo", "name": "CEO Agent" },
    { "id": "finance-agent", "principal_id": "finance-head", "name": "Finance Agent" },
    { "id": "sales-agent", "principal_id": "sales-head", "name": "Sales Agent" }
  ],

  "edges": [
    {
      "from": "ceo",
      "to": "ceo-agent",
      "layer": "institutional",
      "domain": "decision",
      "relationship": "represents",
      "weight": 1.0
    },
    {
      "from": "ceo",
      "to": "finance-agent",
      "layer": "institutional",
      "domain": "decision",
      "relationship": "governs",
      "weight": 0.9
    },
    {
      "from": "ceo",
      "to": "sales-agent",
      "layer": "institutional",
      "domain": "decision",
      "relationship": "governs",
      "weight": 0.9
    }
  ],

  "conflict": {
    "domain": "decision",
    "proposals": [
      { "id": "p1", "agent": "ceo-agent", "action": "approve_budget" },
      { "id": "p2", "agent": "finance-agent", "action": "defer_budget" },
      { "id": "p3", "agent": "sales-agent", "action": "increase_budget" }
    ]
  },

  "resolution": {
    "rule": "selected = argmax(authority(agent, context))",
    "authority_scores": {
      "ceo-agent": 1.0,
      "finance-agent": 0.9,
      "sales-agent": 0.9
    },
    "selected_agent": "ceo-agent",
    "selected_principal": "ceo",
    "reason": "All three agents hold institutional authority; ceo-agent wins on within-layer weight (1.0 > 0.9). finance-agent and sales-agent tie at 0.9 — absent the CEO, the tie-break in spec/resolution.md would select finance-agent by lexicographic agent id."
  }
}
